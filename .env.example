# MongoDB Atlas connection string
# Get from: https://cloud.mongodb.com → Clusters → Connect → Drivers
MONGODB_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/thakkartraders?retryWrites=true&w=majority

# JWT Secret — use a long random string, minimum 32 characters
JWT_SECRET=your_super_secret_jwt_key_minimum_32_chars

# Admin credentials — change these before going live
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Thakkar@2026

# Resend API key — get this from resend.com after creating a free account and verifying your domain or using their sandbox
RESEND_API_KEY=your_resend_api_key_here

# This is the email address where all new inquiry notification emails will be delivered
ADMIN_EMAIL=your_admin_email@example.com

# Cloudinary credentials
# Get from: https://cloudinary.com → Dashboard → Account Details
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Server port (default 5000 if not set)
PORT=5000

# Frontend URL (for CORS — set to your Vercel URL in production)
CLIENT_URL=http://localhost:5173
